      "5": "дє”",
      "6": "е…­",
      "7": "дёѓ",
      "8": "е…«",
      "9": "д№ќ",
      "10": "еЌЃ"
    }
  },

  "clock": {
    "interval": 60,
    "format": "пЃі  {:%e %b %Y %I:%M %p}",
    "tooltip": true,
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt>{calendar}</tt>"
  },

  "cpu": {
    "interval": 10,
    "format": "пѓ§  {usage}%",
    "states": {
      "warning": 70,
      "critical": 90
    }
