    "interval": 10
  },

  "custom/speaker": {
    "format": "{icon}",
    "format-icons": {
      "connected": "п„Њ пЂЊ",
      "disconnected": "п„Њ пЂЌ"
    },
    "return-type": "json",
    "exec": "/usr/local/bin/btdevices speaker",
    "on-click": "/usr/local/bin/btdevices speaker toggle",
    "interval": 10
  },

  "sway/mode": {
    "format": "<span style=\"\">{}</span>",
    "tooltip": false
  },

  "sway/window": {
    "format": "{}",
    "max-length": 240
  },

  "sway/workspaces": {
    "all-outputs": true,
    "disable-scroll": true,
    "format": "{name}"
  },

  "idle_inhibitor": {
