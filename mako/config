anchor=top-center
text-alignment=center
width=400
max-history=10
sort=-time

on-button-left=invoke-default-action
on-button-middle=exec makoctl menu -n $id bemenu -p 'Select action: '
on-button-right=dismiss

max-visible=10
font=ProggyVector 9
max-icon-size=38
padding=12

background-color=#000000aa
text-color=#ffffff
border-color=#ccccccdd
border-size=2
border-radius=5
default-timeout=10000

[urgency=low]
background-color=#000000aa
text-color=#aaaaaa
border-color=#666666dd
border-size=2
border-radius=5
default-timeout=10000


[urgency=normal]
background-color=#000000aa
text-color=#ffffff
border-color=#ccccccdd
border-size=2
border-radius=5
default-timeout=10000


[urgency=critical]
background-color=#000000aa
text-color=#ffffff
border-color=#B4140Fdd
border-size=2
border-radius=5
default-timeout=0

