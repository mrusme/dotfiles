#!/bin/sh
# 
# For xdg-open to use this script run:
# xdg-settings set default-web-browser browser.desktop
#
# browser.desktop is located in:
# ~/.local/share/applications/browser.desktop
#
# It contains the following:
#
# [Desktop Entry]
# Type=Application
# Name=browser
# Comment=Browser Picker
# Terminal=false
# Exec=/usr/local/bin/browser
# Categories=Network;WebBrowser
# MimeType=x-scheme-handler/unknown;x-scheme-handler/about;x-scheme-handler/https;x-scheme-handler/http;text/html;


read -d '\n' browsers << EOF
firefox
librewolf
chromium
tor-browser
nyxt
EOF

url="$1"

# https://github.com/thegeeklab/url-parser
host=$(url-parser host --url "$url")

selected_browser="firefox"

# if test "${url#*$".onion"}" != "$url"
if [ "$(expr "$host" : '^.*\.onion$')" -gt 0 ]
then
  selected_browser="tor-browser"
else
  # When launched from an X11 application, this doesn't work and crashes with
  # the following error:
  #
  # (wofi:3815): Gdk-CRITICAL **: 15:01:24.831: 
  # gdk_wayland_display_get_wl_display: assertion 
  # 'GDK_IS_WAYLAND_DISPLAY (display)' failed
  # Failed to connect to wayland compositor
  #
  # Hence, the `*)` case defaults to firefox, so it will at least open the URL
  selected_browser=$(echo "$browsers" | wofi --dmenu)
fi

case $selected_browser in
  "firefox")
    exec /usr/local/bin/ff "$url"
    ;;
  "librewolf")
    exec /usr/local/bin/lw "$url"
    ;; 
  "chromium")
    exec chromium "$url"
    ;;
  "tor-browser")
    exec /usr/local/bin/tb "$url"
    ;;
  "nyxt")
    exec nyxt "$url"
    ;;
  *)
    # Default to firefox
    exec /usr/local/bin/ff "$url"
    ;;
esac

